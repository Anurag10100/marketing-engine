# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=postgresql://user:password@host:5432/elets_brand_engine

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Allowed email domains (pipe-separated)
# Only these domains can log in
ALLOWED_EMAIL_DOMAINS=elets.in|eletsgroup.com

# Feature flags
ENABLE_EXPORT=true
MAX_LEARNINGS_PER_ORG=500
